{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Keyscape",
  "version": "0.3.0",
  "identifier": "app.keyscape.desktop",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Keyscape",
        "width": 1200,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"],
    "resources": {
      "binaries/keyscape-core.exe": "./keyscape-core.exe",
      "binaries/effects/": "./examples/js-effects/"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
